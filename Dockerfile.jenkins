FROM jenkins/jenkins:lts

USER root

# Install Python 3.12 and dependencies
RUN apt-get update && \
    apt-get install -y \
    python3 \
    python3-pip \
    python3-venv \
    git \
    && rm -rf /var/lib/apt/lists/*

# Create symbolic links for python commands
RUN ln -s /usr/bin/python3 /usr/bin/python

# Switch back to jenkins user
USER jenkins